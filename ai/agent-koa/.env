# Server port
PORT=8787

# Storage provider
DB_PROVIDER=sqlite

# SQLite database file
SQLITE_PATH=./data/agent.db

# OpenAI-compatible model config
OPENAI_API_KEY=codex
OPENAI_BASE_URL=https://ai.letus.lol/v1
OPENAI_MODEL=gpt-5.4

# Leave empty to disable Authorization check
AGENT_API_TOKEN=

# ReAct loop safety
AGENT_MAX_ITERATIONS=8
AGENT_TOOL_MAX_CALLS=12
AGENT_TOOL_TIMEOUT_MS=8000

# Sliding context window
AGENT_CONTEXT_ROUNDS=6

# Tool router settings
TOOL_ROUTER_TOP_K=3
TOOL_ROUTER_KEYWORD_MIN_SCORE=1
TOOL_ROUTER_EMBED_TIMEOUT_MS=60000
TOOL_ROUTER_VECTOR_MIN_SCORE=0.50
TOOL_ROUTER_VECTOR_MIN_SCORE_IF_NO_KEYWORD=0.48

# Local embedding model via Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=bge-m3

# MCP servers (JSON array)
MCP_SERVERS_JSON=[]

# PostgreSQL settings (used only when DB_PROVIDER=postgres)
# DB_PROVIDER=postgres
# PG_CONNECTION_STRING=postgresql://postgres:postgres@127.0.0.1:5432/agent_koa
# PG_SCHEMA=public
# PG_POOL_MAX=20
# PG_IDLE_TIMEOUT_MS=30000
# PG_CONNECT_TIMEOUT_MS=5000

