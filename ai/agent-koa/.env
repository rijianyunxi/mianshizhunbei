OPENAI_API_KEY=sk-632abaab39ec41d1a18014e5a977beeb
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen3.5-plus


# Optional. If set, all requests must carry Authorization: Bearer <token>
AGENT_API_TOKEN=
AGENT_MAX_HISTORY=24


# ReAct loop safety
AGENT_MAX_ITERATIONS=8
AGENT_TOOL_MAX_CALLS=12

# Sliding window keeps system prompt + latest rounds
AGENT_CONTEXT_ROUNDS=6

# Tool router (RAG for tools)
TOOL_ROUTER_TOP_K=3
TOOL_ROUTER_EMBED_TIMEOUT_MS=60000
OLLAMA_BASE_URL=http://127.0.0.1:11434
#OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_MODEL=bge-m3
TOOL_ROUTER_VECTOR_MIN_SCORE=0.50
TOOL_ROUTER_VECTOR_MIN_SCORE_IF_NO_KEYWORD=0.48

# Postgres storage
PG_CONNECTION_STRING=postgresql://postgres:postgres@127.0.0.1:5432/agent_koa
PG_SCHEMA=public
PG_POOL_MAX=20
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECT_TIMEOUT_MS=5000

# CLI default endpoint
AGENT_BASE_URL=http://localhost:8787

# MCP servers (JSON array)
# Example uses the built-in demo MCP server in this repo.
MCP_SERVERS_JSON=[{"id":"smart-site-demo","command":"node","args":["src/mcp/demoSmartSiteServer.js"],"cwd":".","enabled":true}]
