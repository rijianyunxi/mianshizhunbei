PORT=8787
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini
AGENT_API_TOKEN=

# ReAct loop safety
AGENT_MAX_ITERATIONS=8
AGENT_TOOL_MAX_CALLS=12
AGENT_TOOL_TIMEOUT_MS=8000

# Sliding window keeps system prompt + latest rounds
AGENT_CONTEXT_ROUNDS=6

# Tool router (RAG for tools)
TOOL_ROUTER_TOP_K=3
TOOL_ROUTER_EMBED_TIMEOUT_MS=2000
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# Checkpoint storage
SQLITE_PATH=./data/agent-checkpoints.sqlite

# CLI default endpoint
AGENT_BASE_URL=http://localhost:8787

# MCP servers (JSON array)
# Example uses the built-in demo MCP server in this repo.
MCP_SERVERS_JSON=[{"id":"smart-site-demo","command":"node","args":["src/mcp/demoSmartSiteServer.js"],"cwd":".","enabled":true}]
# Hot-swap test plugin example:
# MCP_SERVERS_JSON=[{"id":"hot-swap-test","command":"node","args":["src/mcp/hotSwapTestServer.js"],"cwd":".","enabled":true}]
# Chrome DevTools MCP example (auto-load on server restart):
# MCP_SERVERS_JSON=[{"id":"smart-site-demo","command":"node","args":["src/mcp/demoSmartSiteServer.js"],"cwd":".","enabled":true},{"id":"chrome-devtools","command":"npx","args":["-y","chrome-devtools-mcp@latest"],"cwd":".","enabled":true}]
