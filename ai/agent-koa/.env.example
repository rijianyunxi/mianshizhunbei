PORT=8787
DB_PROVIDER=sqlite
SQLITE_PATH=./data/agent.db
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini
AGENT_API_TOKEN=

# ReAct loop safety
AGENT_MAX_ITERATIONS=8
AGENT_TOOL_MAX_CALLS=12
AGENT_TOOL_TIMEOUT_MS=8000

# Sliding window keeps system prompt + latest rounds
AGENT_CONTEXT_ROUNDS=6

# Tool router (RAG for tools)
TOOL_ROUTER_TOP_K=3
TOOL_ROUTER_EMBED_TIMEOUT_MS=2000
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# SQLite is the default storage provider.
# Set DB_PROVIDER=postgres to switch to PostgreSQL.

# Postgres storage
PG_CONNECTION_STRING=postgresql://postgres:postgres@127.0.0.1:5432/agent_koa
PG_SCHEMA=public
PG_POOL_MAX=20
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECT_TIMEOUT_MS=5000

# MCP servers (JSON array)
# Default keeps MCP disabled. Fill a valid JSON array if you want auto-start.
MCP_SERVERS_JSON=[]
